        "displayNameCN": "闪电",
        "emoji": "⚡️",
        "theme": "coding expert",
        "toolsProfile": "coding",
        "model": "openai-codex/gpt-5.3-codex",
        "username": "",
        "notify": {
          "telegram": {
            "enabled": false,
            "chatId": ""
          }
        }
      },
      "product": {
        "displayName": "Product",
        "displayNameCN": "诺娃",
