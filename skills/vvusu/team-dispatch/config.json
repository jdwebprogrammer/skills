        "theme": "product planning",
        "toolsProfile": "full",
        "model": "openai-codex/gpt-5.2",
        "username": "",
        "notify": { "telegram": { "enabled": false, "chatId": "" } }
      },
      "tester": {
        "displayName": "Tester",
        "displayNameCN": "亚特拉斯",
