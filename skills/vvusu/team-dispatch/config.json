{
  "version": "1.0.5",
  "language": "zh",
  "languageNote": "Switch to 'zh' for Chinese output. Default is English. 切换为 'zh' 输出中文，默认为英文。",
  "notifyPolicy": "failures-only",
  "paths": {
    "projectsRoot": "~/work",
    "projectsRootNote": "Default real project code directory. Agents should create repos/projects under this folder (e.g. ~/work/<project>)."
  },
  "notifyPolicyNote": "Options: 'all' | 'failures-only' | 'none'. 选项：'all' 全部通知 | 'failures-only' 仅失败 | 'none' 不通知",
  "team": {
    "watcher": {
      "enabled": true,
      "backend": "openclaw-cron",
      "interval": 90,
      "grace": 20,
      "jobName": "Team Dispatch watcher",
      "jobDescription": "Low-frequency reconciliation: scan tasks/active for overdue in-progress tasks and reset to pending when retries remain.",
      "note": "Cross-platform background watcher installer. backend: openclaw-cron|auto|auto-system-first|launchd|systemd|cron"
    },
    "main": {
      "displayName": "main",
      "displayNameCN": "调度台",
      "emoji": "🎯",
      "model": "openai-codex/gpt-5.2"
    },
    "agents": {
